# ═══════════════════════════════════════════════════════════════
#  yt_downloader — Configuration
# ═══════════════════════════════════════════════════════════════

# ── Quality ──────────────────────────────────────────────────
# YES = download the absolute highest resolution available
# NO  = cap at 1080p (falls back to highest available if 1080p isn't present)
HIGHEST_RES=NO

# YES = download audio only as MP3 (320kbps)
# NO  = download video
DOWNLOAD_AUDIO_ONLY=NO

# ── Paths ────────────────────────────────────────────────────
# Directory where downloaded files will be saved
DOWNLOAD_DIR=./downloads

# File containing URLs to download (one per line)
LINKS_FILE=./links.txt

# ── Cookies (bot bypass) ─────────────────────────────────────
# Option 1: Path to a Netscape-format cookies.txt file
# COOKIES_FILE=./cookies.txt

# Option 2: Extract cookies directly from a browser
# Supported: chrome, firefox, edge, brave, opera, vivaldi
# COOKIES_FROM_BROWSER=chrome

# ── Behavior ─────────────────────────────────────────────────
# Number of parallel downloads (keep at 1 for stability)
MAX_CONCURRENT_DOWNLOADS=1

# Retry attempts for failed downloads
MAX_RETRIES=3

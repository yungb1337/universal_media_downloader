<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for sites that don't support HTTPS.
         yt-dlp handles TLS itself, but some metadata endpoints use HTTP. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
